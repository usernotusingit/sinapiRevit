#!/usr/bin/env bash
# Determinism hash gate (see tools/hash_gate.py).
#
# The orçamento outputs are no longer committed (regenerable via `make regen`), so the
# tracked deterministic artifact is the crosswalk: crosswalk/revit_sinapi_map.csv.
# Committing a change to it is a claim that it reproduces from the current code +
# inputs — this verifies that claim (and re-checks any output/ files present on disk)
# and rejects the commit if they don't. Logic-only commits that don't touch the
# crosswalk CSV are not gated.
#
# Enable once per clone:  git config core.hooksPath .githooks
set -euo pipefail

staged="$(git diff --cached --name-only)"
if echo "$staged" | grep -qE '^crosswalk/revit_sinapi_map\.csv$'; then
  echo "[hash-gate] crosswalk map staged — verifying determinism..."
  if ! python3 tools/hash_gate.py; then
    echo ""
    echo "[hash-gate] REJECTED: crosswalk/outputs do not reproduce from current source."
    echo "  Fix: regenerate, then commit again:"
    echo "    make regen   # (or run src/parse_revit.py -> build_crosswalk.py -> apply_review.py ...)"
    exit 1
  fi
fi

# Spec freshness: if params.md or its snapshot is staged, the snapshot's recorded
# fingerprint must match the current params.md (see tools/spec_gate.py).
if echo "$staged" | grep -qE '^crosswalk/(params\.md|params_spec_system_prompt\.(json|md))$'; then
  echo "[spec-gate] params.md / spec snapshot staged — verifying freshness..."
  if ! python3 tools/spec_gate.py; then
    echo ""
    echo "[spec-gate] REJECTED: the params_spec snapshot is stale vs crosswalk/params.md."
    echo "  Fix: refresh the snapshot + gap docs to match params.md, then re-stamp:"
    echo "    make stamp-spec"
    exit 1
  fi
fi
exit 0
